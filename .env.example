# --- Database ---
APP_DB_PASSWORD=app_session_pw
CONTROL_PLANE_DB_PASSWORD=cp_admin_pw
POSTGRES_PASSWORD=postgres_root_pw
WEB_APP_REDIRECT_URI=http://localhost:13000/callback

# --- Control Plane ---
CP_SIGNING_KEY_PATH=/keys/signing.pem
CP_JWT_TTL_SECONDS=3600
CP_REFRESH_TTL_SECONDS=28800
CP_PUBLIC_URL=http://localhost:18080

# --- Web App ---
WEB_APP_CLIENT_SECRET=web_app_client_secret_change_me
WEB_APP_SESSION_SECRET=change_me_32_byte_hex_session_secret
FLASK_SECRET=change_me_csrf_secret_value

# --- LLM (all required, no defaults) ---
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=500
LLM_MAX_ITERATIONS=5

# --- Agent (headless) ---
CONTROL_PLANE_URL=http://localhost:18080
CLI_AGENT_INTERVAL_SECONDS=15

# --- Delegation chain demo agents (orchestrator_main -> research_specialist) ---
# The web-app needs these to run the dashboard's "Chain: 3-Hop Delegation"
# button (it authenticates AS these agents to extend the chain); also used
# if you're authenticating as these agents directly outside the web UI
# (e.g. curl, or the test suite). The values below match the bcrypt hashes
# seeded in db/init.sql.
ORCHESTRATOR_AGENT_SECRET=agent_orchestrator_secret_change_me
SPECIALIST_AGENT_SECRET=agent_specialist_secret_change_me
